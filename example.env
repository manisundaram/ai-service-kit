"""
Example .env file showing cloud logging configuration.

Copy this to your project and customize the values for your cloud providers.
"""

# =============================================================================
# BASIC LOGGING CONFIGURATION
# =============================================================================

# Service identification
APP_NAME=my-api
APP_ENV=production

# Basic log levels
LOG_LEVEL=INFO                # Console and general file logging
FILE_LOG_LEVEL=DEBUG          # More verbose file logging  
ERROR_FILE_LEVEL=ERROR        # Separate error file

# Logging format and output
LOG_STRUCTURED=true           # JSON structured logs for production
LOG_CONSOLE=true              # Enable console output
LOG_DIR=./logs                # Directory for log files

# Log file rotation
LOG_MAX_FILE_SIZE=10485760    # 10MB before rotation
LOG_BACKUP_COUNT=5            # Keep 5 old files


# =============================================================================
# CLOUD LOGGING PROVIDERS
# =============================================================================

# Comma-separated list of cloud providers to enable
CLOUD_LOGGING_PROVIDERS=aws,datadog

# You can also enable individual providers:
# CLOUD_LOGGING_PROVIDERS=aws
# CLOUD_LOGGING_PROVIDERS=datadog,azure
# CLOUD_LOGGING_PROVIDERS=aws,azure,gcp,datadog


# =============================================================================
# AWS CLOUDWATCH LOGS
# =============================================================================

AWS_LOGGING_ENABLED=true
AWS_LOGGING_LEVEL=ERROR       # Only errors to CloudWatch (cost optimization)
AWS_LOG_GROUP=/my-api/production
AWS_REGION=us-east-1
# AWS_LOG_STREAM=optional-custom-stream-name

# AWS credentials (use IAM roles in production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key


# =============================================================================
# AZURE MONITOR / APPLICATION INSIGHTS
# =============================================================================

AZURE_LOGGING_ENABLED=false   # Set to true to enable
AZURE_LOGGING_LEVEL=ERROR     # Warnings and above to Azure
AZURE_CONNECTION_STRING=InstrumentationKey=your-instrumentation-key


# =============================================================================
# GOOGLE CLOUD LOGGING
# =============================================================================

GCP_LOGGING_ENABLED=false     # Set to true to enable  
GCP_LOGGING_LEVEL=WARNING     # Warnings and above to GCP
# GCP_PROJECT_ID=your-project-id  # Optional, uses default project


# =============================================================================
# DATADOG LOGS
# =============================================================================

DATADOG_LOGGING_ENABLED=true
DATADOG_LOGGING_LEVEL=INFO    # All info+ logs to Datadog
DATADOG_API_KEY=your-datadog-api-key


# =============================================================================
# EXAMPLE COST-OPTIMIZED CONFIGURATION
# =============================================================================

# For cost optimization, send only errors to expensive cloud services:
# 
# CLOUD_LOGGING_PROVIDERS=aws
# AWS_LOGGING_LEVEL=ERROR      # Only errors to CloudWatch
# 
# Local files get everything:
# LOG_LEVEL=INFO               # Info+ to console
# FILE_LOG_LEVEL=DEBUG         # Debug+ to files


# =============================================================================
# EXAMPLE HIGH-OBSERVABILITY CONFIGURATION  
# =============================================================================

# For maximum observability in critical production:
#
# CLOUD_LOGGING_PROVIDERS=aws,datadog,azure
# AWS_LOGGING_LEVEL=WARNING    # Warnings+ to CloudWatch
# DATADOG_LOGGING_LEVEL=INFO   # Info+ to Datadog (great search/dashboards)
# AZURE_LOGGING_LEVEL=ERROR    # Errors to Azure (alerting)


# =============================================================================
# EXAMPLE DEVELOPMENT CONFIGURATION
# =============================================================================

# For local development:
#
# APP_ENV=development
# LOG_LEVEL=DEBUG
# LOG_STRUCTURED=false         # Readable console output
# CLOUD_LOGGING_PROVIDERS=     # No cloud logging in dev