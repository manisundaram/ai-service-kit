# =============================================================================
# DEVELOPMENT CONFIGURATION - LOCAL FILE LOGGING ONLY
# =============================================================================

# Basic service info
APP_NAME=my-api
APP_ENV=development

# Local logging configuration
LOG_LEVEL=INFO                    # Console shows INFO+
FILE_LOG_LEVEL=DEBUG              # Files capture everything  
ERROR_FILE_LEVEL=ERROR            # Separate error file
LOG_STRUCTURED=false              # Human-readable format for development
LOG_CONSOLE=true                  # Show logs in console
LOG_DIR=./logs                    # Store logs in ./logs directory

# File rotation settings
LOG_MAX_FILE_SIZE=5242880         # 5MB before rotation (smaller for dev)
LOG_BACKUP_COUNT=3                # Keep 3 old files

# =============================================================================
# DISABLE ALL CLOUD LOGGING  
# =============================================================================

# Method 1: Empty providers list (recommended for development)
CLOUD_LOGGING_PROVIDERS=

# Method 2: Explicitly disable each provider
# AWS_LOGGING_ENABLED=false
# AZURE_LOGGING_ENABLED=false
# GCP_LOGGING_ENABLED=false  
# DATADOG_LOGGING_ENABLED=false

# =============================================================================
# RESULT: LOCAL FILES ONLY
# =============================================================================

# This configuration will create:
# 
# ./logs/my-api.log        - All DEBUG+ logs (JSON if structured=true)
# ./logs/my-api_error.log  - ERROR+ logs only
# ./logs/my-api_daily.log  - Daily rotation logs
#
# Console will show INFO+ logs in readable format
# NO cloud providers will be contacted
# NO API keys or credentials required
# NO external dependencies needed